generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  nombre    String?
  rol       String   @default("vendedor")
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("usuarios")
}

model Cliente {
  id                  Int                  @id @default(autoincrement())
  nombre              String
  email               String               @unique
  telefono            String?
  distrito            String?
  mascotas            Int                  @default(0)
  status              String               @default("activo")
  ultimaCompra        DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  password            String?
  wizardCompletado    Boolean              @default(false)
  mascotasDetalle     Mascota[]
  passwordResetTokens PasswordResetToken[]
  pushSubscriptions   PushSubscription[]
  suscripciones       Suscripcion[]

  @@map("clientes")
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  clienteId Int
  tokenHash String    @unique
  expiresAt DateTime
  used      Boolean   @default(false)
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  cliente   Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId], map: "password_reset_tokens_clienteId_fkey")
  @@map("password_reset_tokens")
}

model Mascota {
  id                  Int             @id @default(autoincrement())
  nombre              String
  especie             String
  raza                String?
  edad                String?
  pesoKg              Float?
  clienteId           Int
  vacunasAlDia        Boolean         @default(false)
  ultimaRevision      String?         @default("—")
  proximaDosis        String?         @default("—")
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  razaId              Int?
  actividad           String?         @default("activo")
  alergiasMascota     String?         @db.Text
  castrado            Boolean         @default(false)
  condicion           String?
  sexo                String?
  tratamientosMascota String?         @db.Text
  vacunasMascota      String?         @db.Text
  objetivo            String?         @default("Normal")
  foto                String?         @db.LongText
  historialPesos      HistorialPeso[]
  cliente             Cliente         @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  razaRel             Raza?           @relation(fields: [razaId], references: [id])
  suscripciones       Suscripcion[]

  @@index([clienteId], map: "mascotas_clienteId_fkey")
  @@index([razaId], map: "mascotas_razaId_fkey")
  @@map("mascotas")
}

model Raza {
  id            Int       @id @default(autoincrement())
  nombre        String
  promedioVida  Float?
  promedioPeso  Float?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  categoria     String?
  umbralMadurez Float?
  mascotas      Mascota[]

  @@map("razas")
}

model Configuracion {
  id                  Int      @id @default(autoincrement())
  razonSocial         String?
  nombreComercial     String?
  ruc                 String?
  direccionFiscal     String?
  departamento        String?
  telefono            String?
  email               String?
  serieBoleta         String?
  numeroSiguiente     Int      @default(1)
  encabezadoBoleta    String?
  direccionBoleta     String?
  leyendaSunat        String?
  updatedAt           DateTime @updatedAt
  landingBannerActivo Boolean  @default(false)
  landingBannerUrl    String?  @db.Text

  @@map("configuracion")
}

model Producto {
  id             Int      @id @default(autoincrement())
  nombre         String
  descripcion    String?
  imagenUrl      String?
  precioUnitario Float    @default(0)
  cantidad       Float    @default(0)
  unidad         String   @default("unidad")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("productos")
}

model Receta {
  id               Int                 @id @default(autoincrement())
  nombre           String
  precio           Float               @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  descripcionCorta String?             @db.Text
  descripcionLarga String?             @db.Text
  formula          String?             @db.Text
  imagen           String?             @db.Text
  indicacionMedica String?             @db.Text
  beneficios       RecetaBeneficio[]
  etiquetas        RecetaEtiqueta[]
  ingredientes     RecetaIngrediente[]
  precios          RecetaPrecio[]

  @@map("recetas")
}

model RecetaIngrediente {
  id        Int    @id @default(autoincrement())
  recetaId  Int
  categoria String
  insumo    String
  cantidad  String
  receta    Receta @relation(fields: [recetaId], references: [id], onDelete: Cascade)

  @@index([recetaId], map: "receta_ingredientes_recetaId_fkey")
  @@map("receta_ingredientes")
}

model RecetaPrecio {
  id          Int      @id @default(autoincrement())
  recetaId    Int
  sku         String
  precioBolsa Float
  precioPlan  Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  receta      Receta   @relation(fields: [recetaId], references: [id], onDelete: Cascade)

  @@index([recetaId], map: "receta_precios_recetaId_fkey")
  @@map("receta_precios")
}

model RecetaEtiqueta {
  id       Int    @id @default(autoincrement())
  recetaId Int
  nombre   String
  icono    String
  receta   Receta @relation(fields: [recetaId], references: [id], onDelete: Cascade)

  @@index([recetaId], map: "receta_etiquetas_recetaId_fkey")
  @@map("receta_etiquetas")
}

model RecetaBeneficio {
  id          Int    @id @default(autoincrement())
  recetaId    Int
  titulo      String
  descripcion String @db.Text
  icono       String
  receta      Receta @relation(fields: [recetaId], references: [id], onDelete: Cascade)

  @@index([recetaId], map: "receta_beneficios_recetaId_fkey")
  @@map("receta_beneficios")
}

model Antipulga {
  id           Int      @id @default(autoincrement())
  tipo         String
  nombre       String
  frecuencia   String
  marcas       String   @db.Text
  notificacion String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("antipulgas")
}

model Notificacion {
  id          Int      @id @default(autoincrement())
  nombre      String
  mensaje     String   @db.Text
  vencimiento DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("notificaciones")
}

model Alergia {
  id          Int      @id @default(autoincrement())
  alergia     String
  descripcion String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("alergias")
}

model Vacuna {
  id          Int      @id @default(autoincrement())
  nombre      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  descripcion String?  @db.Text
  frecuencia  String?  @db.Text
  recurrente  Boolean  @default(false)

  @@map("vacunas")
}

model Suscripcion {
  id             Int      @id @default(autoincrement())
  clienteId      Int
  mascotaId      Int?
  plan           String
  proximaEntrega DateTime
  estado         String   @default("activa")
  montoBase      Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  recetaId       Int?
  recetaNombre   String?
  cantidadBolsas Int?     @default(1)
  estadoPedido   String?  @default("pendiente")
  gramosPorBolsa Int?     @default(0)
  resumenBolsas  String?
  cliente        Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  mascota        Mascota? @relation(fields: [mascotaId], references: [id], onDelete: Cascade)

  @@index([clienteId], map: "suscripciones_clienteId_fkey")
  @@index([mascotaId], map: "suscripciones_mascotaId_fkey")
  @@map("suscripciones")
}

model HistorialPeso {
  id        Int      @id @default(autoincrement())
  mascotaId Int
  pesoKg    Float
  nota      String?
  fecha     DateTime @default(now())
  mascota   Mascota  @relation(fields: [mascotaId], references: [id], onDelete: Cascade)

  @@index([mascotaId], map: "historial_peso_mascotaId_fkey")
  @@map("historial_peso")
}

model Descuento {
  id          Int      @id @default(autoincrement())
  nombre      String
  fechaInicio DateTime
  fechaFin    DateTime
  porcentaje  Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  activo      Boolean  @default(true)
  tipoCliente String   @default("nuevo_cliente")

  @@map("descuentos")
}

model DatoCurioso {
  id          Int      @id @default(autoincrement())
  datoCurioso String   @db.Text
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("datos_curiosos")
}

model Recomendacion {
  id          Int      @id @default(autoincrement())
  titulo      String
  descripcion String   @db.Text
  categoria   String   @default("General")
  icono       String   @default("star")
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("recomendaciones")
}

model ZonaEnvio {
  id        Int      @id @default(autoincrement())
  distrito  String   @unique
  costo     Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("zonas_envio")
}

model CondicionCorporal {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique
  descripcion String   @db.Text
  mensaje     String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("condiciones_corporales")
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  clienteId Int
  endpoint  String   @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  createdAt DateTime @default(now())
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId], map: "push_subscriptions_clienteId_fkey")
  @@map("push_subscriptions")
}

model Pago {
  id              Int      @id @default(autoincrement())
  preferenceId    String?  @unique
  paymentId       String?  @unique
  externalRef     String?  @unique
  monto           Float
  estado          String   @default("pending")
  metodo          String?
  clienteId       Int?
  mascotaId       Int?
  suscripcionData String?  @db.Text
  procesado       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("pagos")
}
