// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  nombre    String?
  rol       String   @default("vendedor")
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("usuarios")
}

model Cliente {
  id           Int      @id @default(autoincrement())
  nombre       String
  email        String   @unique
  password     String?
  telefono     String?
  distrito     String?
  mascotas     Int      @default(0)
  wizardCompletado Boolean @default(false)
  status       String   @default("activo") // activo, pausado, sin_suscripcion
  ultimaCompra DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  mascotasDetalle Mascota[]
  suscripciones   Suscripcion[]
  pushSubscriptions PushSubscription[]

  @@map("clientes")
}

model Mascota {
  id             Int      @id @default(autoincrement())
  nombre         String
  especie        String   // Perro, Gato
  raza           String?
  sexo           String?
  castrado       Boolean  @default(false)
  actividad      String?  @default("activo")
  edad           String?
  pesoKg         Float?
  condicion      String?
  objetivo       String?  @default("Normal")
  alergiasMascota String? @db.Text
  vacunasMascota  String? @db.Text
  tratamientosMascota String? @db.Text
  clienteId      Int
  cliente        Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  vacunasAlDia   Boolean  @default(false)
  ultimaRevision String?  @default("—")
  proximaDosis   String?  @default("—")
  foto           String?  @db.LongText
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  razaId         Int?
  razaRel        Raza?    @relation(fields: [razaId], references: [id])
  suscripciones  Suscripcion[]
  historialPesos HistorialPeso[]

  @@map("mascotas")
}

model Raza {
  id           Int      @id @default(autoincrement())
  nombre        String   @unique
  promedioVida  Float?
  promedioPeso  Float?
  categoria     String?
  umbralMadurez Float?
  mascotas      Mascota[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("razas")
}

model Configuracion {
  id                Int      @id @default(autoincrement())

  // Info General
  razonSocial       String?
  nombreComercial   String?
  ruc               String?
  direccionFiscal   String?
  departamento      String?
  telefono          String?
  email             String?

  // Boleta
  serieBoleta       String?
  numeroSiguiente   Int      @default(1)
  encabezadoBoleta  String?
  direccionBoleta   String?
  leyendaSunat      String?
  piePagina         String?

  updatedAt         DateTime @updatedAt

  @@map("configuracion")
}

model Producto {
  id             Int      @id @default(autoincrement())
  nombre         String
  descripcion    String?
  imagenUrl      String?
  precioUnitario Float    @default(0)
  cantidad       Float    @default(0) // Float because unit can be kg/g/l/ml
  unidad         String   @default("unidad") // kg, g, l, ml, unidad
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("productos")
}

model Receta {
  id               Int       @id @default(autoincrement())
  nombre           String
  precio           Float     @default(0) // Costo o precio por receta
  
  imagen           String?   @db.Text
  descripcionCorta String?   @db.Text
  descripcionLarga String?   @db.Text
  indicacionMedica String?   @db.Text
  formula          String?   @db.Text

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  ingredientes   RecetaIngrediente[]
  precios        RecetaPrecio[]
  etiquetas      RecetaEtiqueta[]
  beneficios     RecetaBeneficio[]

  @@map("recetas")
}

model RecetaIngrediente {
  id           Int      @id @default(autoincrement())
  recetaId     Int
  categoria    String   // "Proteina 60%", "Carbohidrato 25%", etc.
  insumo       String   // "Pollo", etc.
  cantidad     String   // "400 gr", etc.
  
  receta       Receta   @relation(fields: [recetaId], references: [id], onDelete: Cascade)

  @@map("receta_ingredientes")
}

model RecetaPrecio {
  id           Int      @id @default(autoincrement())
  recetaId     Int
  sku          String
  precioBolsa  Float
  precioPlan   Float
  
  receta       Receta   @relation(fields: [recetaId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("receta_precios")
}

model RecetaEtiqueta {
  id           Int      @id @default(autoincrement())
  recetaId     Int
  nombre       String
  icono        String
  
  receta       Receta   @relation(fields: [recetaId], references: [id], onDelete: Cascade)

  @@map("receta_etiquetas")
}

model RecetaBeneficio {
  id           Int      @id @default(autoincrement())
  recetaId     Int
  titulo       String
  descripcion  String   @db.Text
  icono        String
  
  receta       Receta   @relation(fields: [recetaId], references: [id], onDelete: Cascade)

  @@map("receta_beneficios")
}

model Antipulga {
  id           Int      @id @default(autoincrement())
  tipo         String   
  nombre       String   
  frecuencia   String   
  marcas       String   @db.Text
  notificacion String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("antipulgas")
}

model Notificacion {
  id          Int      @id @default(autoincrement())
  nombre      String   
  mensaje     String   @db.Text
  vencimiento DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("notificaciones")
}

model Alergia {
  id          Int      @id @default(autoincrement())
  alergia     String   
  descripcion String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("alergias")
}

model Vacuna {
  id          Int      @id @default(autoincrement())
  nombre      String   
  descripcion String?  @db.Text
  recurrente  Boolean  @default(false)
  frecuencia  String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("vacunas")
}

model Suscripcion {
  id               Int      @id @default(autoincrement())
  clienteId        Int
  cliente          Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  mascotaId        Int?
  mascota          Mascota? @relation(fields: [mascotaId], references: [id], onDelete: Cascade)
  plan             String   // "semanal", "quincenal", "mensual"
  proximaEntrega   DateTime
  estado           String   @default("activa") // "activa", "pausada", "cancelada"
  montoBase        Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("suscripciones")
}

model HistorialPeso {
  id          Int      @id @default(autoincrement())
  mascotaId   Int
  pesoKg      Float
  nota        String?
  fecha       DateTime @default(now())

  mascota     Mascota  @relation(fields: [mascotaId], references: [id], onDelete: Cascade)

  @@map("historial_peso")
}

model Descuento {
  id          Int      @id @default(autoincrement())
  nombre      String
  fechaInicio DateTime
  fechaFin    DateTime
  porcentaje  Float
  tipoCliente String   @default("nuevo_cliente") // "nuevo_cliente" | "cliente_recurrente"
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("descuentos")
}

model DatoCurioso {
  id          Int      @id @default(autoincrement())
  datoCurioso String   @db.Text
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("datos_curiosos")
}

model Recomendacion {
  id          Int      @id @default(autoincrement())
  titulo      String
  descripcion String   @db.Text
  categoria   String   @default("General") // Actividad, Salud, Nutricion, General
  icono       String   @default("star")     // Material Symbols icon name
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("recomendaciones")
}

model ZonaEnvio {
  id          Int      @id @default(autoincrement())
  distrito    String   @unique
  costo       Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("zonas_envio")
}

model CondicionCorporal {
  id          Int      @id @default(autoincrement())
  nombre      String   @unique  // "Delgado", "Ideal", "Sobrepeso"
  descripcion String   @db.Text // descripción visible en el wizard
  mensaje     String?  @db.Text // aviso médico (ej: "Detectamos sobrepeso...")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt


  @@map("condiciones_corporales")
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  clienteId Int
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  endpoint  String   @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}
